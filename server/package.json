{
    "name":  "server",
    "version":  "0.1.0",
    "private":  true,
    "main":  "dist/server.js",
    "scripts":  {
                    "dev":  "tsx watch src/server.ts",
                    "build":  "tsc -p tsconfig.json",
                    "start":  "node dist/server.js",
                    "type-check":  "tsc -p tsconfig.json --noEmit",
                    "lint":  "eslint \"src/**/*.ts\"",
                    "db:generate":  "prisma generate",
                    "db:push":  "prisma db push",
                    "db:migrate":  "prisma migrate dev",
                    "db:seed":  "tsx prisma/seed.ts"
                },
    "dependencies":  {
                         "@dreamboat/shared":  "workspace:*",
                         "@prisma/client":  "^6.5.0",
                         "bcrypt":  "^6.0.0",
                         "cookie-parser":  "^1.4.7",
                         "cors":  "^2.8.5",
                         "dotenv":  "^16.4.7",
                         "express":  "^5.1.0",
                         "express-rate-limit":  "^8.3.1",
                         "helmet":  "^8.1.0",
                         "http-status-codes":  "^2.3.0",
                         "jsonwebtoken":  "^9.0.2",
                         "pino":  "^9.9.0",
                         "pino-http":  "^10.5.0",
                         "zod":  "^4.1.5"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.24.0",
                            "@types/bcrypt":  "^6.0.0",
                            "@types/cookie-parser":  "^1.4.8",
                            "@types/cors":  "^2.8.18",
                            "@types/express":  "^5.0.3",
                            "@types/jsonwebtoken":  "^9.0.10",
                            "@types/node":  "^22.14.1",
                            "eslint":  "^9.24.0",
                            "prisma":  "^6.5.0",
                            "tsx":  "^4.19.3",
                            "typescript":  "^5.8.2",
                            "typescript-eslint":  "^8.29.1"
                        }
}
